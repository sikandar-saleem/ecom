<div class="row  justify-content-center">
  <div class="col-lg-10 mt-4">
    <div class="card" class="img-show-card">
      <div class="card-body">

        <% if @item.image.attached? %>
          <%= image_tag @item.image, class:"img-show" %>
        <% else %>
          <img src="skelton.jpg" class="img-show"/>
        <% end %>

        <div class="text-center">
          <h4 class="card-title mt-2"><%= @item.title%></h4>
          <strong class="card-text">Rs. <%= @item.price%></strong>
          <p class="card-text"><%= @item.description%></p>
        </div>
      </div>
    </div>
  </div>
</div>
